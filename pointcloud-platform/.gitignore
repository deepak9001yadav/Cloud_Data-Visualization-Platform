# ============================================================================
# .gitignore - Point Cloud Visualization Platform
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Docker
.dockerignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Uploads and Processed Files (local development)
backend/uploads/*
!backend/uploads/.gitkeep
backend/processed/*
!backend/processed/.gitkeep

# Logs
*.log
logs/

# Environment Variables
.env
.env.local

# Temporary Files
*.tmp
temp/
tmp/
